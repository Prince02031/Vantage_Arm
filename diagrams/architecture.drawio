        <mxCell id="edge_in_keyboard" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.32;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="input_keyboard" target="exec_broker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_in_sliders" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="input_sliders" target="exec_broker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_in_pin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.68;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="input_pin" target="exec_broker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_in_voice" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="input_voice" target="exec_broker">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Command Broker -> Safety Validator -->
        <mxCell id="edge_broker_validator" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6e3a1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="exec_broker" target="validator">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Safety Validator -> IK Solver / FK Model -->
        <mxCell id="edge_val_ik" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.15;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="validator" target="ik_solver">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge_val_fk" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.85;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="validator" target="fk_model">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- IK Solver <--> FK Model -->
        <mxCell id="edge_ik_fk" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#f9e2af;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="ik_solver" target="fk_model">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- IK Solver -> Trajectory Runner -->
        <mxCell id="edge_ik_traj" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#a6adc8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.15;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="ik_solver" target="traj_runner">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Trajectory Runner -> Robot Adapter -->
        <mxCell id="edge_traj_adapter" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#cba6f7;strokeWidth=2;exitX=0.15;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="traj_runner" target="robot_adapter">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Robot Adapter <--> ThreeScene Object Graph -->
        <mxCell id="edge_adapter_scene" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#fab387;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="robot_adapter" target="three_scene">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Bi-directional connections to the Central State Store -->
        <!-- Broker updates and listens to store -->
        <mxCell id="edge_broker_store" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#89dceb;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.08;entryDx=0;entryDy=0;" edge="1" parent="1" source="exec_broker" target="state_store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Validator reads store -->
        <mxCell id="edge_val_store" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#89dceb;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="validator" target="state_store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Trajectory updates store on every frame -->
        <mxCell id="edge_traj_store" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#89dceb;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.68;entryDx=0;entryDy=0;" edge="1" parent="1" source="traj_runner" target="state_store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Scene reads/writes to store -->
        <mxCell id="edge_scene_store" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#89dceb;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.9;entryDx=0;entryDy=0;" edge="1" parent="1" source="three_scene" target="state_store">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
